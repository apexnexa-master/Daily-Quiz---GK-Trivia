        "30"
      ],
      "bn": [
        "২৫",
        "২০",
        "৩৫",
        "৩০"
      ]
    },
    "explanation": {
      "en": "15% of 200 = (15/100) × 200 = 30.",
      "hi": "200 का 15% = (15/100) × 200 = 30।",
      "bn": "200 এর 15% = (15/100) × 200 = 30।"
