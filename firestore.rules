rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the current user is authenticated (simplified for testing/dev authorization)
    function isAdmin() {
      return request.auth != null;
    }

    // ── Admin collection ──────────────────────────────────
    match /admin/{email} {
      allow read: if request.auth != null;
      allow write: if false; // Admins can only be managed manually/via console
    }

    // ── Quiz timing settings ──────────────────────────────
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() &&
                    request.resource.data.start_hour is int &&
                    request.resource.data.start_hour >= 0 && request.resource.data.start_hour <= 23 &&
                    request.resource.data.end_hour is int &&
                    request.resource.data.end_hour >= 0 && request.resource.data.end_hour <= 23;
    }

    // ── Users ──────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /attempts/{attemptId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      match /streak/{docId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // ── Quizzes ──────────────────────────────────────────
    match /quizzes/{quizId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();

      match /questions/{questionId} {
        allow read: if request.auth != null;
        allow delete: if isAdmin();
        allow create, update: if isAdmin() &&
                      request.resource.data.correct_index is int &&
                      request.resource.data.correct_index >= 0 &&
                      request.resource.data.correct_index <= 3;
      }
    }

    // ── Collection Group rule for questions (allows collection group queries) ──
    match /{path=**}/questions/{questionId} {
      allow read: if request.auth != null;
      allow delete: if isAdmin();
      allow create, update: if isAdmin() &&
                    request.resource.data.correct_index is int &&
                    request.resource.data.correct_index >= 0 &&
                    request.resource.data.correct_index <= 3;
    }

    // ── Practice questions ────────────────────────────────
    match /practice/{examMode} {
      allow read: if request.auth != null;
      allow write: if isAdmin() &&
                    request.resource.data.exam_mode == examMode &&
                    request.resource.data.questions is list;
    }

    // ── Leaderboard ────────────────────────────────────────
    match /leaderboard/{entryId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Challenges ─────────────────────────────────────────
    match /challenges/{challengeId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
